# Frontend Environment Variables
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000
VITE_ENV=development
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_OFFLINE_MODE=false

# Backend Environment Variables
PORT=5000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/linguadev

# AWS Configuration
# Get credentials from AWS Console > IAM > Users > Security Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# AWS Bedrock (AI Chat)
# Request access: AWS Console > Bedrock > Model access
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# AWS S3 (File Storage)
# Create bucket: AWS Console > S3 > Create bucket
AWS_S3_BUCKET=linguadev-user-files

# AWS CloudWatch (Logging)
# Logs will be sent to this log group
AWS_CLOUDWATCH_LOG_GROUP=/linguadev/application

# AWS DynamoDB (NoSQL Database)
# Create tables: AWS Console > DynamoDB > Create table
DYNAMODB_USERS_TABLE=linguadev-users
DYNAMODB_PROGRESS_TABLE=linguadev-progress
DYNAMODB_COURSES_TABLE=linguadev-courses
DYNAMODB_PROJECTS_TABLE=linguadev-projects

# Redis / AWS ElastiCache (Caching & Sessions)
# For local development:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# For AWS ElastiCache:
# ELASTICACHE_ENDPOINT=your-cluster.cache.amazonaws.com

# AWS CloudFront (CDN)
# Create distribution: AWS Console > CloudFront > Create distribution
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id
CLOUDFRONT_DOMAIN=your-domain.cloudfront.net

# AWS EventBridge (Event-Driven Architecture)
# Events will be published to this event bus
EVENTBRIDGE_BUS_NAME=default

# AWS Cognito (Authentication & Authorization)
# Create user pool: AWS Console > Cognito > Create user pool
AWS_COGNITO_USER_POOL_ID=your-user-pool-id
AWS_COGNITO_CLIENT_ID=your-client-id
AWS_COGNITO_REGION=us-east-1

# AWS KMS (Key Management Service)
# Create key: AWS Console > KMS > Create key
AWS_KMS_KEY_ID=your-kms-key-id

# AWS X-Ray (Distributed Tracing)
# Enable X-Ray tracing for performance monitoring
AWS_XRAY_ENABLED=false
AWS_XRAY_DAEMON_ADDRESS=127.0.0.1:2000

# AWS WAF (Web Application Firewall)
# Create web ACL: AWS Console > WAF > Create web ACL
AWS_WAF_ENABLED=false
AWS_WAF_WEB_ACL_ID=your-web-acl-id

# Optional: Use AWS Profile instead of access keys
# AWS_PROFILE=your-profile-name

# Database (for production - replace in-memory storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/linguadev
